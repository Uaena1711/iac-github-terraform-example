# Per-stack identity for the dev workspace (live demo against a throwaway account).
# Provider is chosen HERE, at the file level. ${REF} values are resolved by the catalog's
# resolve-env action from that provider; plain values pass through untouched.
SECRETS_PROVIDER=github
AWS_ROLE_ARN=arn:aws:iam::377521353143:role/iac-github-oidc-test
AWS_REGION=us-east-1
# Resolved from the GitHub Actions repository variable TF_STATE_BUCKET_DEV.
AWS_STATE_BUCKET=${TF_STATE_BUCKET_DEV}
