# Terraform input variables injected as TF_VAR_* (masked, never written to disk).
# Each KEY becomes TF_VAR_<KEY>; ${REF} is pulled from the provider, literals pass through.
# dev resolves the sensitive value from a GitHub SECRET named DEMO_SECRET_NOTE_DEV.
SECRETS_PROVIDER=github
secret_note=${DEMO_SECRET_NOTE_DEV}
