# Per-stack identity for the prod workspace. Uses the github provider so every job runs in
# the default container (jq auto-installs) — no host needed.
SECRETS_PROVIDER=github
AWS_ROLE_ARN=arn:aws:iam::377521353143:role/iac-github-oidc-test
AWS_REGION=us-east-1
# Resolved from the GitHub Actions repository variable TF_STATE_BUCKET_PROD.
AWS_STATE_BUCKET=${TF_STATE_BUCKET_PROD}
