# Per-stack identity for the prod workspace (live demo against a throwaway account).
# Provider = awssm: ${REF} values are pulled from AWS Secrets Manager AFTER the OIDC role
# is assumed, so the identity fields below stay literal (awssm can't resolve them yet).
SECRETS_PROVIDER=awssm
AWS_ROLE_ARN=arn:aws:iam::377521353143:role/iac-github-oidc-test
AWS_REGION=us-east-1
# Resolved from the Secrets Manager secret iac-github/demo/state-bucket.
AWS_STATE_BUCKET=${iac-github/demo/state-bucket}
